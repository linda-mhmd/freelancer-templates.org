{
  "id": "basic-render",
  "name": "Basic CLI Rendering",
  "cursor": {
    "enabled": false
  },
  "overlays": [
    {
      "type": "highlight",
      "startFrame": 15,
      "endFrame": 90,
      "region": { "x": 50, "y": 100, "width": 600, "height": 30 },
      "style": {
        "color": "#f59e0b",
