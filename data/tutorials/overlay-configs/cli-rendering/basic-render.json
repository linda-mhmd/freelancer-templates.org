    {
      "type": "annotation",
      "startFrame": 15,
      "endFrame": 90,
      "text": "npx remotion render <composition>",
      "position": { "x": 50, "y": 60 },
      "style": {
        "fontSize": 18,
        "color": "#ffffff",
        "background": "#f59e0b"
      }
    }
  ]
}
